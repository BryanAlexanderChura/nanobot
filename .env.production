# ══════════════════════════════════════════════════════════════════
# Nanobot VPS Production — .env template
# ══════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.production .env
#
# NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────
# Pick ONE provider block and uncomment it.

# Option A: OpenAI-compatible (GLM, etc.)
NANOBOT_AGENTS__DEFAULTS__PROVIDER=openai
NANOBOT_AGENTS__DEFAULTS__MODEL=YOUR_MODEL_NAME
NANOBOT_PROVIDERS__OPENAI__API_BASE=https://your-api-base/v1
NANOBOT_PROVIDERS__OPENAI__API_KEY=your-api-key-here

# Option B: Anthropic (via LiteLLM)
# NANOBOT_AGENTS__DEFAULTS__PROVIDER=litellm
# NANOBOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-haiku-4-5-20251001
# NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=sk-ant-...

# Option C: Gemini (via LiteLLM)
# NANOBOT_AGENTS__DEFAULTS__PROVIDER=litellm
# NANOBOT_AGENTS__DEFAULTS__MODEL=gemini/gemini-flash-latest
# NANOBOT_PROVIDERS__GEMINI__API_KEY=AIza...

# ── Agent defaults ───────────────────────────────────────────────
NANOBOT_AGENTS__DEFAULTS__TEMPERATURE=0.3
NANOBOT_AGENTS__DEFAULTS__MAX_TOKENS=4096
NANOBOT_AGENTS__DEFAULTS__THINKING=false

# ── WhatsApp (Evolution API) ────────────────────────────────────
NANOBOT_CHANNELS__WHATSAPP__ENABLED=true
NANOBOT_CHANNELS__WHATSAPP__PROVIDER=evolution
# NOTE: These two are overridden in docker-compose.prod.yml for internal networking.
# Keep them here as fallback / for reference.
NANOBOT_CHANNELS__WHATSAPP__EVOLUTION_API_URL=http://whatsapp-api:8080
NANOBOT_CHANNELS__WHATSAPP__EVOLUTION_API_KEY=nanobot-evo-local-key
NANOBOT_CHANNELS__WHATSAPP__EVOLUTION_INSTANCE=nanobot-test
NANOBOT_CHANNELS__WHATSAPP__ALLOW_FROM=[]

# ── Evolution API config ────────────────────────────────────────
# Change EVOLUTION_SERVER_URL to your VPS public URL so QR links work.
EVOLUTION_API_KEY=nanobot-evo-local-key
EVOLUTION_HOST_PORT=8085
EVOLUTION_SERVER_URL=http://YOUR_VPS_IP:8085
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── Webhook / Gateway ───────────────────────────────────────────
NANOBOT_GATEWAY__WEBHOOK_ENABLED=true
NANOBOT_GATEWAY__WEBHOOK_SECRET=change-me-to-a-strong-secret

# ── Supabase (GAR CRM) ──────────────────────────────────────────
NANOBOT_TOOLS__SUPABASE__URL=https://YOUR_PROJECT.supabase.co
NANOBOT_TOOLS__SUPABASE__SERVICE_KEY=your-supabase-service-key
